<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 儿童端(绿色主题)玻璃卡片 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E8F5E9" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#20A5D6A7"
                android:centerColor="#05A5D6A7"
                android:endColor="#10A5D6A7"
                android:type="linear" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#30A5D6A7" />
        </shape>
    </item>
</layer-list>
